{
  "manifest_version": 3,
  "name": "Blindboxd",
  "default_locale": "en",
  "version": "1.0.3",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://letterboxd.com/*",
        "*://www.letterboxd.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "blindboxd@rsilly.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}